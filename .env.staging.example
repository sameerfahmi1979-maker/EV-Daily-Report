# Copy to .env.staging (gitignored) and fill with STAGING project values only.
# Never paste production keys here.

APP_ENV=staging
VITE_APP_ENV=staging

SUPABASE_PROJECT_REF=your-staging-project-ref
VITE_SUPABASE_URL=https://your-staging-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-anon-key

# Server/tooling only — never expose in frontend bundles
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
SUPABASE_DB_PASSWORD=your-strong-db-password
# Prefer pooler session mode on IPv4-only networks:
# postgresql://postgres.<ref>:<password>@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres
