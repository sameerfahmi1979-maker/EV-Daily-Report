# Supabase project credentials (use service role key — this server runs server-side only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Port — Railway sets this automatically; for local dev use 3001
PORT=3001

# Public WSS domain (informational only — chargers connect to this)
# OCPP_PUBLIC_URL=wss://ws.energy-stream.net/ocpp/<chargePointId>
